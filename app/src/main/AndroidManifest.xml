<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- usesCleartextTraffic Y uses-permission SON NECESARIOS PARA PERMITIR CONEXION CON WS -->
    <uses-permission android:name="android.permission.INTERNET" />
    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Carrito_01"
        tools:targetApi="31">

        <activity
            android:name=".MenuActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar"
            tools:ignore="DiscouragedApi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
<!-- android:screenOrientation="landscape" --> <!-- Agregar esto si queremos volver a fijar la pantalla horizontalmente. -->
        <activity
            android:name=".MainActivity"

            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Carrito_01"
            tools:ignore="DiscouragedApi">

        </activity>
        <activity android:name=".SettingsActivity"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

    </application>
    <uses-permission-sdk-23 android:name="android.permission.CAMERA" />

</manifest>