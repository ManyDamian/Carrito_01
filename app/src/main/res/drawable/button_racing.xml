<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Efecto cuando se presiona -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#B71C1C"/> <!-- Rojo oscuro al presionar -->
            <corners android:radius="10dp"/> <!-- Bordes redondeados -->
            <stroke android:width="4dp" android:color="#FFD700"/> <!-- Borde dorado -->
        </shape>
    </item>

    <!-- Estado normal -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF0000"/> <!-- Rojo brillante -->
            <corners android:radius="10dp"/>
            <stroke android:width="4dp" android:color="#FFD700"/> <!-- Borde dorado -->
            <padding android:left="20dp" android:right="20dp" android:top="10dp" android:bottom="10dp"/>
        </shape>
    </item>
</selector>
